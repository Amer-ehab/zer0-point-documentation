<!-- ============================================================ -->
<!-- Wazuh Rule: Privilege Escalation Detection -->
<!-- File: /var/ossec/etc/rules/local_rules.xml -->
<!-- Description: Detects suspicious privilege escalation attempts -->
<!-- Event IDs: 4672 (Special privileges assigned), 4728 (Member added to security-enabled group) -->
<!-- MITRE ATT&CK: T1078 (Valid Accounts) -->
<!-- ============================================================ -->

<group name="windows,windows_security,privilege_escalation,">
    <rule id="100003" level="10">
        <if_sid>18107</if_sid>
        <field name="win.system.eventID">^4672$</field>
        <description>Special privileges assigned to new logon - Possible Privilege Escalation</description>
        <mitre>
            <id>T1078</id>
        </mitre>
        <group>privilege_escalation,</group>
    </rule>

    <rule id="100004" level="12">
        <if_sid>18107</if_sid>
        <field name="win.system.eventID">^4728$</field>
        <description>Member added to security-enabled global group - Possible Privilege Escalation</description>
        <mitre>
            <id>T1078</id>
        </mitre>
        <group>privilege_escalation,</group>
    </rule>
</group>
