<!-- ============================================================ -->
<!-- Wazuh Rule: Lateral Movement Detection -->
<!-- File: /var/ossec/etc/rules/local_rules.xml -->
<!-- Description: Detects potential lateral movement via network logons -->
<!-- Event IDs: 4624 (Successful logon), 4648 (Explicit credential logon) -->
<!-- MITRE ATT&CK: T1021 (Remote Services) -->
<!-- ============================================================ -->

<group name="windows,windows_security,lateral_movement,">
    <rule id="100005" level="8" frequency="3" timeframe="60">
        <if_matched_sid>18107</if_matched_sid>
        <field name="win.eventdata.logonType">^3$</field>
        <description>Multiple network logons detected - Possible Lateral Movement</description>
        <mitre>
            <id>T1021</id>
        </mitre>
        <group>lateral_movement,</group>
    </rule>

    <rule id="100006" level="10">
        <if_sid>18107</if_sid>
        <field name="win.system.eventID">^4648$</field>
        <description>Explicit credentials used for logon - Possible Lateral Movement</description>
        <mitre>
            <id>T1021</id>
        </mitre>
        <group>lateral_movement,</group>
    </rule>
</group>
